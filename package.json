{
  "name": "model-view",
  "private": false,
  "version": "0.1.0",
  "description": "React weather model viewer backed by local NOAA GRIB2 rendering",
  "scripts": {
    "dev": "node scripts/local-dev.js",
    "dev:vite": "vite",
    "local:build": "node scripts/build-noaa-beta-artifacts.js",
    "local:data": "node scripts/local-data-server.js",
    "local:dev": "node scripts/local-dev.js",
    "local:clear-cache": "node scripts/clear-render-cache.js",
    "cache:clear": "node scripts/clear-render-cache.js",
    "palettes:generate": "node scripts/generate-public-color-maps.js",
    "palettes:qa": "node scripts/generate-palette-qa-report.js",
    "palettes:check": "npm run palettes:generate && npm run palettes:qa",
    "noaa:build": "node scripts/build-noaa-beta-artifacts.js",
    "noaa:build:full": "node scripts/build-noaa-beta-recent-runs.js",
    "noaa:build:test": "node scripts/build-noaa-beta-test-render.js",
    "noaa:snow-rf:export": "node scripts/export-snow-rf-model.js",
    "noaa:data": "node scripts/local-data-server.js",
    "noaa:dev": "node scripts/local-dev.js",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "maintainability:report": "node scripts/maintainability-report.js",
    "smoke": "npm run smoke:react",
    "smoke:react": "playwright test -c playwright.react.config.js --workers=1 --reporter=line",
    "smoke:react:headed": "playwright test -c playwright.react.config.js --workers=1 --reporter=line --headed",
    "test:react": "playwright test -c playwright.react.config.js --reporter=line",
    "test:local-runtime": "node --test tests-node/noaa-beta.test.js",
    "test:local-integration": "node tests-node/local-integration.js",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "pngjs": "^7.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "picomatch": "4.0.4",
    "rollup": "4.61.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.5"
  }
}
